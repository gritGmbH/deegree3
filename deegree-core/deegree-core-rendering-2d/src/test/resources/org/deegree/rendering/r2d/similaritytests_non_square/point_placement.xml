<?xml version="1.0"?>
<FeatureTypeStyle xmlns="http://www.opengis.net/se"
                  xmlns:ogc="http://www.opengis.net/ogc"
                  xmlns:app="http://deegree.org/app"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xmlns:xlink="http://www.w3.org/1999/xlink"
                  xsi:schemaLocation="http://www.opengis.net/se https://schemas.opengis.net/se/1.1.0/FeatureStyle.xsd http://www.opengis.net/ogc https://schemas.opengis.net/filter/1.1.0/filter.xsd">

 	<!-- Point MARK Anchorpoint -->
    <Rule>
        <ogc:Filter>
            <ogc:Or>
	            <ogc:PropertyIsEqualTo>
	                <ogc:PropertyName>app:id</ogc:PropertyName>
	                <ogc:Literal>1</ogc:Literal>
	            </ogc:PropertyIsEqualTo>
	            <ogc:PropertyIsEqualTo>
	                <ogc:PropertyName>app:id</ogc:PropertyName>
	                <ogc:Literal>2</ogc:Literal>
	            </ogc:PropertyIsEqualTo>
            </ogc:Or>            
        </ogc:Filter>
        <PointSymbolizer>
            <Graphic>
                <Mark>
                    <WellKnownName>x</WellKnownName>
                </Mark>
                <Size>5</Size>
            </Graphic>
        </PointSymbolizer>
        <PointSymbolizer>
            <Graphic>
                <Mark>
                    <WellKnownName>triangle</WellKnownName>
                    <Fill>
                        <SvgParameter name="fill">#ff0000</SvgParameter>
                    </Fill>
                    <Stroke>
                        <SvgParameter name="stroke">#000000</SvgParameter>
                    </Stroke>
                </Mark>
                <Size>48</Size>
                <Rotation>
                	<ogc:PropertyName>app:rotation</ogc:PropertyName>
                </Rotation>
                <AnchorPoint>
                    <AnchorPointX>1</AnchorPointX>
                    <AnchorPointY>1</AnchorPointY>
                </AnchorPoint>
            </Graphic>
        </PointSymbolizer>
        <PointSymbolizer>
            <Graphic>
                <Mark>
                    <WellKnownName>triangle</WellKnownName>
                    <Fill>
                        <SvgParameter name="fill">#00ff00</SvgParameter>
                    </Fill>
                    <Stroke>
                        <SvgParameter name="stroke">#000000</SvgParameter>
                    </Stroke>
                </Mark>
                <Size>48</Size>
                <Rotation>
                	<ogc:PropertyName>app:rotation</ogc:PropertyName>
                </Rotation>
                <AnchorPoint>
                    <AnchorPointX>0</AnchorPointX>
                    <AnchorPointY>1</AnchorPointY>
                </AnchorPoint>
            </Graphic>
        </PointSymbolizer>
        <PointSymbolizer>
            <Graphic>
                <Mark>
                    <WellKnownName>triangle</WellKnownName>
                    <Fill>
                        <SvgParameter name="fill">#0000ff</SvgParameter>
                    </Fill>
                    <Stroke>
                        <SvgParameter name="stroke">#000000</SvgParameter>
                    </Stroke>
                </Mark>
                <Size>48</Size>
                <Rotation>
                	<ogc:PropertyName>app:rotation</ogc:PropertyName>
                </Rotation>
                <AnchorPoint>
                    <AnchorPointX>1</AnchorPointX>
                    <AnchorPointY>0</AnchorPointY>
                </AnchorPoint>
            </Graphic>
        </PointSymbolizer>
        <PointSymbolizer>
            <Graphic>
                <Mark>
                    <WellKnownName>triangle</WellKnownName>
                    <Fill>
                        <SvgParameter name="fill">#ffff00</SvgParameter>
                    </Fill>
                    <Stroke>
                        <SvgParameter name="stroke">#000000</SvgParameter>
                    </Stroke>
                </Mark>
                <Size>48</Size>
                <Rotation>
                	<ogc:PropertyName>app:rotation</ogc:PropertyName>
                </Rotation>
                <AnchorPoint>
                    <AnchorPointX>0</AnchorPointX>
                    <AnchorPointY>0</AnchorPointY>
                </AnchorPoint>
            </Graphic>
        </PointSymbolizer>
    </Rule>
